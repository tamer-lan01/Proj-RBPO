    {
      "name": "Owners",
      "item": [
        {
          "name": "Create owner",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/owners",
              "path": ["api", "owners"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ivan\",\n  \"lastName\": \"Ivanov\",\n  \"phone\": \"123456\",\n  \"email\": \"owner{{$timestamp}}@lab.local\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var json = pm.response.json();",
                  "  pm.collectionVariables.set('ownerId', json.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get owner by id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/owners/{{ownerId}}",
              "path": ["api", "owners", "{{ownerId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Get pets of owner",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/owners/{{ownerId}}/pets",
              "path": ["api", "owners", "{{ownerId}}", "pets"]
            }
          },
          "response": []
        },
        {
          "name": "Update owner",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/owners/{{ownerId}}",
              "path": ["api", "owners", "{{ownerId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"IvanUpdated\",\n  \"lastName\": \"IvanovUpdated\",\n  \"phone\": \"654321\",\n  \"email\": \"ivan.updated{{$timestamp}}@lab.local\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Delete owner",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/owners/{{ownerId}}",
              "path": ["api", "owners", "{{ownerId}}"]
            }
