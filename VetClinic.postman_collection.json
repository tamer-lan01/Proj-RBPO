    {
      "name": "Operations (assignment 3)",
      "item": [
        {
          "name": "1 Admit pet with appointment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/operations/admit-pet-with-appointment",
              "path": ["api", "operations", "admit-pet-with-appointment"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ownerId\": {{ownerId}},\n  \"petName\": \"Buddy\",\n  \"species\": \"Dog\",\n  \"breed\": \"Beagle\",\n  \"vetId\": {{vetId}},\n  \"dateTime\": \"2000-06-01T09:00:00\",\n  \"reason\": \"First visit\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "2 Complete visit with treatment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/operations/complete-visit-with-treatment",
              "path": ["api", "operations", "complete-visit-with-treatment"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"appointmentId\": {{appointmentIdWithoutTreatment}},\n  \"proceduresAndMedications\": \"Vaccination\",\n  \"notes\": \"Done in one transaction\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "3 Owner summary (owner + pets)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/operations/owners/{{ownerId}}/summary",
              "path": ["api", "operations", "owners", "{{ownerId}}", "summary"]
            }
          },
          "response": []
        },
        {
          "name": "4 Vet schedule (vet + appointments + pet names)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/operations/vets/{{vetId}}/schedule?from={{scheduleFrom}}&to={{scheduleTo}}",
              "path": ["api", "operations", "vets", "{{vetId}}", "schedule"],
              "query": [
                { "key": "from", "value": "{{scheduleFrom}}" },
                { "key": "to", "value": "{{scheduleTo}}" }
              ]
            }
          },
          "response": []
        },
