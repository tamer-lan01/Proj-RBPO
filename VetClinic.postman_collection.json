                  "try {",
                  "  const body = JSON.parse(pm.request.body.raw);",
                  "  if (body.email) pm.collectionVariables.set('adminEmail', body.email);",
                  "  if (body.password) pm.collectionVariables.set('adminPassword', body.password);",
                  "} catch (e) {}",
                  "if (pm.response.code === 200) {",
